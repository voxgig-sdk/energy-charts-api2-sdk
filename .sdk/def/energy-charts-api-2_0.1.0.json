{
  "openapi": "3.0.3",
  "info": {
    "title": "Energy-Charts API",
    "description": "Provides access to energy data. Allows users to retrieve and analyze energy consumption information.",
    "version": "1.0.0",
    "contact": {
      "url": "https://www.freepublicapis.com/api/random"
    }
  },
  "servers": [
    {
      "url": "https://api.energy-charts.info",
      "description": "Production server"
    }
  ],
  "paths": {
    "/public_power": {
      "get": {
        "summary": "Get power generation data",
        "description": "Retrieves power generation and consumption data for energy analysis",
        "operationId": "getPowerData",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "description": "Country code for energy data",
            "required": false,
            "schema": {
              "type": "string",
              "default": "de"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date for data retrieval (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date for data retrieval (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with energy data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "unix_seconds": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "description": "Array of Unix timestamps"
                    },
                    "production_types": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "Type of energy production"
                          },
                          "data": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            },
                            "description": "Energy production values in MW"
                          }
                        }
                      }
                    },
                    "consumption": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      },
                      "description": "Energy consumption values in MW"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "EnergyData": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the energy data point"
          },
          "value": {
            "type": "number",
            "description": "Energy value in megawatts (MW)"
          },
          "type": {
            "type": "string",
            "description": "Type of energy source (solar, wind, nuclear, etc.)"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Energy Data",
      "description": "Operations related to energy consumption and production data"
    }
  ]
}
